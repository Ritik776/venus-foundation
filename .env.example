# Server-side only — never shipped to the browser.
#
# Powers the /api/videos serverless endpoint, which fetches the YouTube channel
# at runtime so new uploads appear with no rebuild. Set this in your host's
# environment variables (e.g. Vercel → Project → Settings → Environment
# Variables). Restrict the key to "YouTube Data API v3".
#
# Without it, the Media page simply shows no videos (there is no snapshot/fallback).
YOUTUBE_API_KEY=

# Optional — override the channel if it ever changes (defaults to Venus Foundation).
YOUTUBE_CHANNEL_ID=

# ---------------------------------------------------------------------------
# Instagram — powers /api/instagram (live Reels + Posts on the Media page).
#
# Long-lived Instagram User access token (Instagram Graph API). Server-side
# only. Requires an Instagram Business/Creator account linked to a Facebook
# Page + a Meta app. Valid ~60 days — refresh within the window to extend it.
#
# How to get it (one time):
#   1. Convert the IG account to Business/Creator and link a Facebook Page.
#   2. Create an app at https://developers.facebook.com → add the
#      "Instagram" product → "Instagram API setup with Instagram login".
#   3. Add the account as a tester, accept the invite, run the token generator
#      with scopes: instagram_business_basic. Copy the long-lived token.
#
# Refresh (run within 60 days; returns a new token to paste back here):
#   curl "https://graph.instagram.com/refresh_access_token?grant_type=ig_refresh_token&access_token=YOUR_TOKEN"
#
# Without it, the Media page falls back to the curated demo Instagram cards.
IG_ACCESS_TOKEN=
