# Server-side only — never shipped to the browser.
#
# Powers the /api/videos serverless endpoint, which fetches the YouTube channel
# at runtime so new uploads appear with no rebuild. Set this in your host's
# environment variables (e.g. Vercel → Project → Settings → Environment
# Variables). Restrict the key to "YouTube Data API v3".
#
# Without it, the Media page simply shows no videos (there is no snapshot/fallback).
YOUTUBE_API_KEY=

# Optional — override the channel if it ever changes (defaults to Venus Foundation).
YOUTUBE_CHANNEL_ID=
