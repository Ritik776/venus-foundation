{
  "name": "venus-foundation-website",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Venus Foundation — Planting Seeds of Change. A dynamic, content-driven NGO website.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^22.19.19",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0"
  }
}
